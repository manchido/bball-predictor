# ── Odds API ──────────────────────────────────────────────────────────────────
# Primary bookmaker data source: https://the-odds-api.com
# Free tier: 500 requests/month. Aggregates bet365, Pinnacle, William Hill, etc.
ODDS_API_KEY=your_odds_api_key_here


# ── RealGM ────────────────────────────────────────────────────────────────────
REALGM_BASE_URL=https://basketball.realgm.com


# ── Seed for reproducibility ──────────────────────────────────────────────────
SEED=42

# ── Paths (relative to project root) ─────────────────────────────────────────
DATA_DIR=data
MODELS_DIR=models
TRACKING_DIR=tracking
LOGS_DIR=logs

# ── Timezone ──────────────────────────────────────────────────────────────────
TIMEZONE=America/St_Johns

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Scraper throttle ──────────────────────────────────────────────────────────
# Seconds between RealGM requests (respect robots.txt)
REALGM_REQUEST_DELAY=2.0

# ── Odds fallback ─────────────────────────────────────────────────────────────
# "the-odds-api" | "oddsportal"
ODDS_SOURCE=the-odds-api
